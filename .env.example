# Google Analytics - ID de medición (formato G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Search Console - código de verificación (solo el valor, sin "google-site-verification=")
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# URL del sitio (para sitemap y canonical)
# El dominio CANÓNICO que queremos que Google indexe.
# Cuando actives el .com cámbialo aquí.
CANONICAL_URL=https://www.visita-papa-2026.es
SITE_URL=https://www.visita-papa-2026.es

# === Formulario de contacto ===
# Resend (https://resend.com) — free tier 3.000 emails/mes. Crear cuenta,
# verificar el dominio (o usar from@resend.dev en pruebas), y generar API key.
RESEND_API_KEY=

# Email destino del formulario (buzón del responsable)
CONTACT_TO_EMAIL=daniel.mirond@gmail.com

# Email "From" (debe estar verificado en Resend; ideal: contacto@visita-papa-2026.com)
CONTACT_FROM_EMAIL=contacto@visita-papa-2026.com

# Tag de Amazon Afiliados (formato xxxx-21 para Amazon.es).
# Si no se define, el código usa el default 'nuus-21'.
NEXT_PUBLIC_AMAZON_TAG=nuus-21

# Feature flag de la tienda de merchandising.
# - 'true' → la tienda es visible (nav + ruta /tienda accesible)
# - No definido o cualquier otra cosa → la tienda está oculta (404 + sin nav)
# En producción dejar SIN DEFINIR hasta que queramos lanzar la tienda.
NEXT_PUBLIC_SHOP_ENABLED=false
